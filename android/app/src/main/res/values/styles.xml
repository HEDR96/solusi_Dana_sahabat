<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Label kecil di atas setiap grup menu (mis. "MENU", "KEAMANAN") -->
    <style name="ProfileSectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">11.5sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_hint</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:layout_marginStart">4dp</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <!-- Satu baris menu yang bisa diklik (ikon + label + chevron) -->
    <style name="ProfileRow">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">56dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="ProfileRowIcon">
        <item name="android:layout_width">30dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textSize">17sp</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="ProfileRowLabel">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginStart">8dp</item>
        <item name="android:textSize">13.5sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="ProfileRowChevron">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:text">›</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

    <style name="ProfileRowDivider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/background</item>
        <item name="android:layout_marginStart">54dp</item>
    </style>

</resources>
