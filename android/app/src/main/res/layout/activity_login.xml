<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_login_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingHorizontal="28dp"
            android:paddingTop="56dp"
            android:paddingBottom="40dp">

            <!-- ── Brand Section ── -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginBottom="32dp">

                <!-- Logo mark: rounded square gradient -->
                <TextView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:text="SD"
                    android:textSize="28sp"
                    android:textStyle="bold|italic"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="@drawable/bg_login_logo"
                    android:layout_marginBottom="22dp"
                    android:elevation="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Solusi Dana Sahabat"
                    android:textSize="21sp"
                    android:textStyle="bold"
                    android:textColor="#F0F9FF"
                    android:letterSpacing="-0.01"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MULTIFINANCE ERP"
                    android:textSize="10sp"
                    android:textColor="#4D7A99"
                    android:letterSpacing="0.12"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- ── Divider ── -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/bg_login_divider"
                android:layout_marginBottom="28dp" />

            <!-- ── Email Field ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL"
                android:textSize="10sp"
                android:textColor="#4D7A99"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="#0C1B2A"
                app:boxStrokeColor="#1A3050"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="#4D7A99"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                android:layout_marginBottom="18dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:inputType="textEmailAddress"
                    android:imeOptions="actionNext"
                    android:textColor="#D4E8F5"
                    android:textColorHint="#2D5A7A"
                    android:textSize="15sp"
                    android:background="@null" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Password Field ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textSize="10sp"
                android:textColor="#4D7A99"
                android:letterSpacing="0.08"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxBackgroundColor="#0C1B2A"
                app:boxStrokeColor="#1A3050"
                app:boxStrokeWidth="1.5dp"
                app:hintTextColor="#4D7A99"
                app:passwordToggleEnabled="true"
                app:passwordToggleTint="#2D5A7A"
                app:boxCornerRadiusTopStart="14dp"
                app:boxCornerRadiusTopEnd="14dp"
                app:boxCornerRadiusBottomStart="14dp"
                app:boxCornerRadiusBottomEnd="14dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:inputType="textPassword"
                    android:imeOptions="actionDone"
                    android:textColor="#D4E8F5"
                    android:textColorHint="#2D5A7A"
                    android:textSize="15sp"
                    android:background="@null" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── Progress ── -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:indeterminateTint="#0EA5E9"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <!-- ── Login Button ── -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Masuk"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.02"
                android:background="@drawable/bg_login_button"
                android:stateListAnimator="@null"
                android:elevation="0dp" />

            <!-- ── Footer ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0 · CMD Finance"
                android:textSize="11sp"
                android:textColor="#1E3A5F"
                android:letterSpacing="0.05"
                android:layout_marginTop="36dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>
