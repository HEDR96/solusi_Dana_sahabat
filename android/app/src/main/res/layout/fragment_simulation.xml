<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="Simulasi Angsuran"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="@drawable/ic_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── FORM CARD ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parameter Pinjaman"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Leasing dropdown -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilLeasing"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Leasing Tujuan"
                        android:layout_marginBottom="16dp">
                        <AutoCompleteTextView
                            android:id="@+id/ddLeasing"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Input tambahan (muncul setelah leasing dipilih) -->
                    <LinearLayout
                        android:id="@+id/llInputs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <!-- Jenis Produk -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jenis Produk"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/toggleJenis"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnMotor"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="Motor (BPKB)"
                                android:textSize="13sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnMobil"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="Mobil (BPKB)"
                                android:textSize="13sp" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <!-- Jenis Pengajuan -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jenis Pengajuan"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="6dp" />

                        <com.google.android.material.button.MaterialButtonToggleGroup
                            android:id="@+id/togglePengajuan"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnNew"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="NEW"
                                android:textSize="13sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRo"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="0dp"
                                android:layout_height="44dp"
                                android:layout_weight="1"
                                android:text="RO (Repeat Order)"
                                android:textSize="13sp" />
                        </com.google.android.material.button.MaterialButtonToggleGroup>

                        <!-- ── CMD Finance only: Tahun + OTR Lookup ── -->
                        <LinearLayout
                            android:id="@+id/llCmdOtr"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:background="#F1F5F9"
                            android:padding="12dp"
                            android:layout_marginBottom="16dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TAHUN &amp; OTR KENDARAAN"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:textColor="#64748B"
                                android:letterSpacing="0.05"
                                android:layout_marginBottom="10dp" />

                            <!-- Brand -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilBrand"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Brand"
                                android:layout_marginBottom="10dp">
                                <AutoCompleteTextView
                                    android:id="@+id/ddBrand"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Tipe (muncul setelah brand dipilih) -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilTipe"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Tipe"
                                android:layout_marginBottom="10dp"
                                android:visibility="gone">
                                <AutoCompleteTextView
                                    android:id="@+id/ddTipe"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Tahun Kendaraan (muncul setelah tipe dipilih) -->
                            <com.google.android.material.textfield.TextInputLayout
                                android:id="@+id/tilTahun"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Tahun Kendaraan"
                                android:layout_marginBottom="10dp"
                                android:visibility="gone">
                                <AutoCompleteTextView
                                    android:id="@+id/ddTahun"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:inputType="none" />
                            </com.google.android.material.textfield.TextInputLayout>

                            <!-- Maks Pinjaman info -->
                            <LinearLayout
                                android:id="@+id/llMaksPinjaman"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:background="#EFF6FF"
                                android:padding="10dp"
                                android:visibility="gone">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Maks Pinjaman"
                                    android:textSize="11sp"
                                    android:textColor="#64748B" />
                                <TextView
                                    android:id="@+id/tvMaksPinjaman"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#1D4ED8"
                                    android:layout_marginBottom="8dp" />
                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/btnPakaiMaks"
                                    android:layout_width="match_parent"
                                    android:layout_height="40dp"
                                    android:text="Pakai Maks Tersedia"
                                    android:textSize="12sp"
                                    app:cornerRadius="8dp" />
                            </LinearLayout>

                        </LinearLayout>

                        <!-- Jumlah Pencairan — dropdown (muncul setelah tahun dipilih untuk CMD, atau langsung untuk lain) -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPencairan"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Jumlah Pencairan"
                            android:layout_marginBottom="16dp"
                            android:visibility="gone">
                            <AutoCompleteTextView
                                android:id="@+id/ddPencairan"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Tenor -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilTenor"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Tenor"
                            android:layout_marginBottom="4dp"
                            android:visibility="gone">
                            <AutoCompleteTextView
                                android:id="@+id/ddTenor"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── LOADING ── -->
            <ProgressBar
                android:id="@+id/progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:layout_marginBottom="8dp" />

            <!-- ── RESULT AREA ── -->
            <LinearLayout
                android:id="@+id/containerResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
